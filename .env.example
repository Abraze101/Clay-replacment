# Web UI server (pnpm web). Localhost only in M2; real authentication arrives
# at Milestone 6. PGlite is single-connection: never run `pnpm web` and
# `pnpm mcp:http` against the same pglite:// directory at the same time — use
# the PostgreSQL URL below to run both.
WEB_PORT=3000
# Zero-setup local PostgreSQL engine. Use the server URL below with compose.yaml.
DATABASE_URL=pglite://./.data/lead-engine
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/lead_engine
# Optional paths (defaults shown); the fake-enrich ledger is the M0 fake
# provider's persisted request-key dedupe store.
EXPORT_DIR=./exports
FAKE_ENRICH_LEDGER_PATH=./.data/fake-enrich-ledger.json
ENCRYPTION_KEY=
LOG_LEVEL=info
APPROVAL_TOKEN_TTL_MINUTES=30

# MCP Streamable HTTP transport (pnpm mcp:http). Localhost only in M1;
# MCP_HTTP_TOKEN enables a static bearer check (auth-ready stub — real
# authentication arrives at Milestone 6). Leave empty for local use.
MCP_HTTP_PORT=3001
MCP_HTTP_TOKEN=

# Runtime providers (not required for the Apollo MCP prototype)
APOLLO_API_KEY=
GOOGLE_PLACES_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
HUBSPOT_PRIVATE_APP_TOKEN=
