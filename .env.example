# Web UI server (pnpm web). Localhost only in M2; real authentication arrives
# at Milestone 6. PGlite is single-connection: never run `pnpm web` and
# `pnpm mcp:http` against the same pglite:// directory at the same time — use
# the PostgreSQL URL below to run both.
WEB_PORT=3000
# Zero-setup local PostgreSQL engine. Use the server URL below with compose.yaml.
DATABASE_URL=pglite://./.data/lead-engine
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/lead_engine
# Optional paths (defaults shown); the fake-enrich ledger is the M0 fake
# provider's persisted request-key dedupe store.
EXPORT_DIR=./exports
FAKE_ENRICH_LEDGER_PATH=./.data/fake-enrich-ledger.json
ENCRYPTION_KEY=
LOG_LEVEL=info
APPROVAL_TOKEN_TTL_MINUTES=30

# MCP Streamable HTTP transport (pnpm mcp:http). Localhost only in M1;
# MCP_HTTP_TOKEN enables a static bearer check (auth-ready stub — real
# authentication arrives at Milestone 6). Leave empty for local use.
MCP_HTTP_PORT=3001
MCP_HTTP_TOKEN=

# --- Milestone 3: live local-business discovery (SerpAPI Google Maps) ------
# The ONLY key needed for real Quick List runs. Free tier: 250 searches/month;
# one search per location per run (the preview shows the exact count before
# any approval). Test it for free on the UI's Provider setup screen.
SERPAPI_API_KEY=
# Optional tuning (defaults shown):
# SERPAPI_MAX_RPM=10
# SERPAPI_MAX_PAGES_PER_QUERY=6
# SERPAPI_DEFAULT_RETRY_AFTER_SECONDS=60

# --- Milestone 3: optional website research (Firecrawl) --------------------
# Doubly opt-in: BOTH the key and the provider flag. Only used by call-ready/
# full profiles (1 credit per researched site); Quick List never touches it.
FIRECRAWL_API_KEY=
WEBSITE_RESEARCH_PROVIDER=fake
# WEBSITE_RESEARCH_PROVIDER=firecrawl

# Background-job driver. web/mcp entries default to pgboss (delayed rate-limit
# resumes), one-shot CLI to inprocess; set to force one everywhere.
# JOB_DRIVER=pgboss
# Max seconds a one-shot CLI run will wait inline to self-heal a provider
# rate-limit pause before leaving it to a resident worker (pnpm worker).
# RATE_LIMIT_INLINE_WAIT_MAX_SECONDS=120

# --- Milestone 4: professional contacts (Apollo) ---------------------------
# Requires a MASTER API key (Apollo → Settings → API; a regular key 403s on
# people search). People search consumes NO credits and returns NO emails or
# phone numbers; work-email enrichment consumes ~1 credit per matched record
# and only runs in the `full` profile AFTER the review gate and your approval.
# Phone reveal arrives at M5. Basic plan or above recommended for enrichment;
# a free key works for the search probe (rate-limited, last names partially
# obfuscated): pnpm probe:apollo -- --titles "CEO" --locations "Austin, TX" --yes
APOLLO_API_KEY=
# Optional tuning (defaults shown):
# APOLLO_MAX_RPM=30
# APOLLO_MAX_PAGES_PER_QUERY=5
# APOLLO_DEFAULT_RETRY_AFTER_SECONDS=60

# Runtime providers for LATER milestones (leave empty until then):
# model providers at M5; HubSpot after real usage.
GOOGLE_PLACES_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
HUBSPOT_PRIVATE_APP_TOKEN=
