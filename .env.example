# Web UI server (pnpm web). Localhost only in M2; real authentication arrives
# at Milestone 6. PGlite is single-connection: never run `pnpm web` and
# `pnpm mcp:http` against the same pglite:// directory at the same time — use
# the PostgreSQL URL below to run both.
WEB_PORT=3000
# Zero-setup local PostgreSQL engine. Use the server URL below with compose.yaml.
DATABASE_URL=pglite://./.data/lead-engine
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/lead_engine
# Optional paths (defaults shown); the fake-enrich ledger is the M0 fake
# provider's persisted request-key dedupe store.
EXPORT_DIR=./exports
FAKE_ENRICH_LEDGER_PATH=./.data/fake-enrich-ledger.json
ENCRYPTION_KEY=
LOG_LEVEL=info
APPROVAL_TOKEN_TTL_MINUTES=30

# MCP Streamable HTTP transport (pnpm mcp:http). Localhost only in M1;
# MCP_HTTP_TOKEN enables a static bearer check (auth-ready stub — real
# authentication arrives at Milestone 6). Leave empty for local use.
MCP_HTTP_PORT=3001
MCP_HTTP_TOKEN=

# --- Milestone 3: live local-business discovery (SerpAPI Google Maps) ------
# The ONLY key needed for real Quick List runs. Free tier: 250 searches/month;
# one search per location per run (the preview shows the exact count before
# any approval). Test it for free on the UI's Provider setup screen.
SERPAPI_API_KEY=
# Optional tuning (defaults shown):
# SERPAPI_MAX_RPM=10
# SERPAPI_MAX_PAGES_PER_QUERY=6
# SERPAPI_DEFAULT_RETRY_AFTER_SECONDS=60

# --- Milestone 3: optional website research (Firecrawl) --------------------
# Doubly opt-in: BOTH the key and the provider flag. Only used by call-ready/
# full profiles (1 credit per researched site); Quick List never touches it.
FIRECRAWL_API_KEY=
WEBSITE_RESEARCH_PROVIDER=fake
# WEBSITE_RESEARCH_PROVIDER=firecrawl

# Background-job driver. web/mcp entries default to pgboss (delayed rate-limit
# resumes), one-shot CLI to inprocess; set to force one everywhere.
# JOB_DRIVER=pgboss
# Max seconds a one-shot CLI run will wait inline to self-heal a provider
# rate-limit pause before leaving it to a resident worker (pnpm worker).
# RATE_LIMIT_INLINE_WAIT_MAX_SECONDS=120

# --- Milestone 4: professional contacts (Apollo) ---------------------------
# Requires a MASTER API key (developer.apollo.io → API Keys; a regular key
# 403s on people search) AND a paid plan: verified live 2026-07-12, Apollo
# 403s mixed_people/api_search entirely on FREE plans ("not accessible with
# this api_key on a free plan") — a free key can only be created and
# health-checked. People search consumes NO credits and returns NO emails or
# phone numbers; work-email enrichment consumes ~1 credit per matched record
# and only runs in the `full` profile AFTER the review gate and your approval.
# Phone reveal arrives at M5. After upgrading (Basic or above), validate with:
# pnpm probe:apollo -- --titles "CEO" --locations "Austin, TX" --yes
APOLLO_API_KEY=
# Optional tuning (defaults shown):
# APOLLO_MAX_RPM=30
# APOLLO_MAX_PAGES_PER_QUERY=5
# APOLLO_DEFAULT_RETRY_AFTER_SECONDS=60

# --- Milestone 5: contact-enrichment capabilities (ADR-029/030/031) --------
# Each capability binds to a deterministic FAKE provider by default (offline,
# free). A live vendor activates only when BOTH the selection var and its
# key(s) are set. Adapter built ≠ vendor selected: run the benchmarks
# (docs/benchmarks-m5.md, pnpm bench:*) before choosing; final vendor picks
# are recorded in ADR-008/009/010.
PHONE_VALIDATION_PROVIDER=fake
EMAIL_VERIFICATION_PROVIDER=fake
CONTACT_DISCOVERY_PROVIDER=fake
# FAKE_CAPABILITY_LEDGER_PATH=./.data/fake-capability-ledger.json

# Twilio Lookup v2 (phone validation; ADR-009 first candidate). Charged per
# requested signal package per lookup (~$0.008 line type intelligence; line
# status and CNAM priced separately — see twilio.com/lookup/pricing). Identity
# Match is an approval-gated Twilio add-on; leave disabled unless approved.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# TWILIO_MAX_RPM=60
# TWILIO_IDENTITY_MATCH_ENABLED=false

# ZeroBounce / MillionVerifier (email verification; ADR-010 candidates).
# 1 credit per verification; UNKNOWN results are refunded by both vendors.
# Only a 'valid' deliverability result ever sets a lead's verified_email.
ZEROBOUNCE_API_KEY=
MILLIONVERIFIER_API_KEY=
# MILLIONVERIFIER_VENDOR_TIMEOUT_SECONDS=20

# BetterContact / FullEnrich / LeadMagic (contact discovery; ADR-008
# candidates). Charged only on delivered data; phones cost markedly more than
# emails (roughly 5-10x credits, vendor-dependent). BetterContact and
# FullEnrich deliver asynchronously (the engine submits, then polls — no
# webhook needed, ADR-029); LeadMagic is synchronous.
BETTERCONTACT_API_KEY=
FULLENRICH_API_KEY=
LEADMAGIC_API_KEY=
# BETTERCONTACT_POLL_INTERVAL_SECONDS=10
# FULLENRICH_POLL_INTERVAL_SECONDS=15

# --- Milestone 5: model providers (one shared generation interface) --------
# Generation is OPTIONAL: sourcing, scoring, and export run with no model
# provider configured. Selection order when GENERATE_MODEL_PROVIDER is unset
# and multiple keys exist: openrouter > minimax > openai > anthropic
# (ADR-012/032). Model calls bill your own provider account — never engine
# credits. OPENROUTER is the chosen MiniMax route (owner decision 2026-07-13):
# sign up at openrouter.ai, add credits, create a key — MiniMax M3 runs as
# minimax/minimax-m3 (~$0.30/M input, $1.20/M output).
OPENROUTER_API_KEY=
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_MODEL=minimax/minimax-m3
# GENERATE_MODEL_PROVIDER=openrouter
MINIMAX_API_KEY=
# MINIMAX_BASE_URL=https://api.minimax.io
# MINIMAX_MODEL=MiniMax-M3
# OPENAI_MODEL=gpt-5-mini
# ANTHROPIC_MODEL=claude-haiku-4-5
# GENERATE_MAX_OUTPUT_TOKENS=800

# Runtime providers for LATER milestones (leave empty until then):
# HubSpot after real usage.
GOOGLE_PLACES_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
HUBSPOT_PRIVATE_APP_TOKEN=
