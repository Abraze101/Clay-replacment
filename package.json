{
  "name": "lead-engine",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Headless, workflow-driven lead generation engine",
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "leads": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "check": "pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "cli": "tsx src/cli/index.ts",
    "db:migrate": "tsx src/cli/index.ts db migrate",
    "lint": "eslint .",
    "test": "tsx --test test/*.test.ts",
    "typecheck": "tsc --noEmit && tsc -p web/tsconfig.json --noEmit",
    "spike:pgboss": "tsx spikes/pg-boss-pglite/spike.ts",
    "mcp:stdio": "tsx src/mcp/stdio.ts",
    "mcp:http": "tsx src/mcp/http.ts",
    "web": "tsx src/web/server.ts",
    "worker": "tsx src/cli/index.ts worker",
    "probe:apollo": "tsx scripts/probe-apollo.ts",
    "probe:serpapi": "tsx scripts/probe-serpapi-maps.ts",
    "bench:phone": "tsx scripts/bench/phone-validation.ts",
    "bench:email": "tsx scripts/bench/email-verification.ts",
    "bench:discovery": "tsx scripts/bench/contact-discovery.ts",
    "ui:dev": "vite dev --config web/vite.config.ts",
    "ui:build": "vite build --config web/vite.config.ts"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.5.4",
    "@modelcontextprotocol/sdk": "1.29.0",
    "commander": "^15.0.0",
    "csv-parse": "7.0.1",
    "csv-stringify": "6.8.1",
    "dotenv": "^17.4.2",
    "kysely": "0.29.3",
    "libphonenumber-js": "1.13.8",
    "pg": "^8.22.0",
    "pg-boss": "12.25.1",
    "tldts": "7.4.8",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@openai/agents": "0.13.2",
    "@types/node": "^26.1.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tsx": "^4.23.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.4"
  }
}
