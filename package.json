{
  "name": "lead-engine",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Headless, workflow-driven lead generation engine",
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "leads": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "check": "pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "cli": "tsx src/cli/index.ts",
    "db:migrate": "tsx src/cli/index.ts db migrate",
    "lint": "eslint .",
    "test": "tsx --test test/*.test.ts",
    "typecheck": "tsc --noEmit",
    "spike:pgboss": "tsx spikes/pg-boss-pglite/spike.ts"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.5.4",
    "commander": "^15.0.0",
    "csv-stringify": "6.8.1",
    "dotenv": "^17.4.2",
    "kysely": "0.29.3",
    "libphonenumber-js": "1.13.8",
    "pg": "^8.22.0",
    "tldts": "7.4.8",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.1",
    "@types/pg": "^8.20.0",
    "eslint": "^10.6.0",
    "pg-boss": "12.25.1",
    "tsx": "^4.23.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.63.0"
  }
}
